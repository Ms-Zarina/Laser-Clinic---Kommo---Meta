# ──────────────────────────────────────────────────────────────
# Laser Clinic — Kommo → Meta backend
# Copy to .env and fill in real values. NEVER commit the real .env.
# ──────────────────────────────────────────────────────────────

# Meta Conversions API (Dataset / Pixel of Laser Clinic)
META_PIXEL_ID=
META_ACCESS_TOKEN=

# Optional: temporary Test Events code from Events Manager (leave empty in prod)
META_TEST_EVENT_CODE=

# Optional: verify token for Meta Lead webhook (GET /meta/webhook)
META_VERIFY_TOKEN=

# Kommo / amoCRM
KOMMO_SUBDOMAIN=
KOMMO_ACCESS_TOKEN=

# Optional Kommo custom field IDs used to enrich Meta Event Match Quality.
# Leave empty if the field does not exist — empty values are simply not sent.
KOMMO_FBP_FIELD_ID=
KOMMO_FBC_FIELD_ID=
KOMMO_CITY_FIELD_ID=
KOMMO_COUNTRY_FIELD_ID=

# Pipeline status IDs (Kommo) → Meta event mapping
THINKING_STATUS_ID=
BOOKING_STATUS_ID=
SUCCESSFULLY_STATUS_ID=

# Port the app listens on (matches docker-compose / Nginx upstream)
PORT=3001
